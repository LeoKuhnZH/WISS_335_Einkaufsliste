<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical">

    <androidx.appcompat.widget.Toolbar
        android:id="@+id/toolbar"
        android:layout_width="match_parent"
        android:layout_height="?attr/actionBarSize"
        android:background="?attr/colorPrimary"
        app:titleTextColor="@color/white" />

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true">

        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:padding="24dp"
            tools:context=".ItemDetailActivity">

            <!-- Name -->
            <TextView
                android:id="@+id/labelName"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Produktname:"
                android:textSize="14sp"
                android:textColor="#757575"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintStart_toStartOf="parent" />

            <TextView
                android:id="@+id/detailName"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:text="Name"
                android:textSize="24sp"
                android:textStyle="bold"
                android:textColor="@color/black"
                app:layout_constraintTop_toBottomOf="@id/labelName"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent" />

            <EditText
                android:id="@+id/editName"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:hint="Produktname"
                android:visibility="gone"
                android:inputType="textCapSentences"
                app:layout_constraintTop_toBottomOf="@id/labelName"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent" />

            <!-- Quantity -->
            <TextView
                android:id="@+id/labelQuantity"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="24dp"
                android:text="Menge:"
                android:textSize="14sp"
                android:textColor="#757575"
                app:layout_constraintTop_toBottomOf="@id/detailName"
                app:layout_constraintStart_toStartOf="parent" />

            <TextView
                android:id="@+id/detailQuantity"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="0"
                android:textSize="18sp"
                android:textColor="@color/black"
                app:layout_constraintTop_toBottomOf="@id/labelQuantity"
                app:layout_constraintStart_toStartOf="parent" />

            <EditText
                android:id="@+id/editQuantity"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:hint="Menge"
                android:visibility="gone"
                android:inputType="number"
                app:layout_constraintTop_toBottomOf="@id/labelQuantity"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent" />

            <!-- Price -->
            <TextView
                android:id="@+id/labelPrice"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="24dp"
                android:text="Einzelpreis:"
                android:textSize="14sp"
                android:textColor="#757575"
                app:layout_constraintTop_toBottomOf="@id/detailQuantity"
                app:layout_constraintStart_toStartOf="parent" />

            <TextView
                android:id="@+id/detailPrice"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="0.00 €"
                android:textSize="18sp"
                android:textColor="@color/black"
                app:layout_constraintTop_toBottomOf="@id/labelPrice"
                app:layout_constraintStart_toStartOf="parent" />

            <EditText
                android:id="@+id/editPrice"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:hint="Einzelpreis"
                android:visibility="gone"
                android:inputType="numberDecimal"
                app:layout_constraintTop_toBottomOf="@id/labelPrice"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent" />

            <!-- Total -->
            <TextView
                android:id="@+id/labelTotal"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="24dp"
                android:text="Gesamtpreis:"
                android:textSize="14sp"
                android:textColor="#757575"
                app:layout_constraintTop_toBottomOf="@id/detailPrice"
                app:layout_constraintStart_toStartOf="parent" />

            <TextView
                android:id="@+id/detailTotal"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="0.00 €"
                android:textSize="18sp"
                android:textStyle="bold"
                android:textColor="@color/black"
                app:layout_constraintTop_toBottomOf="@id/labelTotal"
                app:layout_constraintStart_toStartOf="parent" />

            <!-- Status -->
            <TextView
                android:id="@+id/labelStatus"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="24dp"
                android:text="Status:"
                android:textSize="14sp"
                android:textColor="#757575"
                app:layout_constraintTop_toBottomOf="@id/detailTotal"
                app:layout_constraintStart_toStartOf="parent" />

            <TextView
                android:id="@+id/detailStatus"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Noch zu kaufen"
                android:textSize="18sp"
                android:textColor="@color/black"
                app:layout_constraintTop_toBottomOf="@id/labelStatus"
                app:layout_constraintStart_toStartOf="parent" />

            <!-- Comment -->
            <TextView
                android:id="@+id/labelComment"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="24dp"
                android:text="Kommentar:"
                android:textSize="14sp"
                android:textColor="#757575"
                app:layout_constraintTop_toBottomOf="@id/detailStatus"
                app:layout_constraintStart_toStartOf="parent" />

            <TextView
                android:id="@+id/detailComment"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:text="Kein Kommentar"
                android:textSize="18sp"
                android:textStyle="italic"
                android:textColor="@color/black"
                app:layout_constraintTop_toBottomOf="@id/labelComment"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent" />

            <EditText
                android:id="@+id/editComment"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:hint="Kommentar"
                android:visibility="gone"
                android:inputType="textCapSentences"
                app:layout_constraintTop_toBottomOf="@id/labelComment"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent" />

            <!-- Save Button -->
            <Button
                android:id="@+id/buttonSave"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="32dp"
                android:text="Speichern"
                android:visibility="gone"
                app:layout_constraintTop_toBottomOf="@id/editComment"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent" />

        </androidx.constraintlayout.widget.ConstraintLayout>
    </ScrollView>
</LinearLayout>